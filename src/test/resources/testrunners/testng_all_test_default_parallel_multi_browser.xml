<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Opencart_basic" verbose="5" thread-count="15" parallel="tests">

    <listeners>
        <listener class-name="com.aventstack.chaintest.plugins.ChainTestListener"></listener>
        <listener class-name="listeners.TestAllureListener"></listener>
        <listener class-name="listeners.AnnotationTransformer"></listener>
    </listeners>


    <test name="Accounts Page Test Chrome">
        <parameter name="browser" value="chrome"></parameter>
        <classes>
            <class name="tests.AccountsPageTest" />
        </classes>
    </test>


    <test name="Accounts Page Test Firefox">
        <parameter name="browser" value="firefox"></parameter>
        <classes>
            <class name="tests.AccountsPageTest" />
        </classes>
    </test>

    <test name="Accounts Page Test Edge">
        <parameter name="browser" value="edge"></parameter>
